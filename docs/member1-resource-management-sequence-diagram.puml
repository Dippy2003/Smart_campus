@startuml
title Sequence Diagram - Resource Management Module

' Layout tuning to reduce crossing/overlap in dense diagrams
skinparam Shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam ParticipantPadding 30
skinparam BoxPadding 12
skinparam NotePadding 10
skinparam maxMessageSize 80

autonumber

actor User
actor Admin
boundary "Resource UI\n(/resources)" as UserUI
boundary "Admin Resource UI\n(/admin/resources)" as AdminUI
control "Resource Controller" as Controller
control "Resource Service" as Service
database "Resource Repository" as Repo
collections "MySQL DB" as DB

== Public Resource Browsing ==
User -> UserUI: Open resources page
UserUI -> Controller: GET /resources
Controller -> Service: getAllActiveResources()
Service -> Repo: findByIsActiveTrue()
Repo -> DB: SELECT active resources
DB --> Repo: Resource rows
Repo --> Service: List<Resource>
Service --> Controller: ResourceDTO list
Controller --> UserUI: 200 OK + resource list
UserUI --> User: Display catalogue

User -> UserUI: Search/filter (type, location, status)
UserUI -> Controller: GET /resources?filters
Controller -> Service: searchResources(filters)
Service -> Repo: queryByFilters(filters)
Repo -> DB: SELECT with filter criteria
DB --> Repo: Matching resources
Repo --> Service: Filtered list
Service --> Controller: Filtered DTO list
Controller --> UserUI: 200 OK + filtered data
UserUI --> User: Show filtered results

User -> UserUI: Open resource details
UserUI -> Controller: GET /resources/{id}
Controller -> Service: getResourceById(id)
Service -> Repo: findById(id)
Repo -> DB: SELECT resource by id
DB --> Repo: Resource record / null
Repo --> Service: Optional<Resource>

alt Resource exists
  Service --> Controller: ResourceDTO
  Controller --> UserUI: 200 OK + details
  UserUI --> User: Show details + availability
else Resource not found
  Service --> Controller: NotFoundException
  Controller --> UserUI: 404 Not Found
  UserUI --> User: Show "resource not found"
end

opt User wants booking
  User -> UserUI: Click "Book Now"
  UserUI --> User: Navigate to booking flow
end

== Admin Resource Management ==
Admin -> AdminUI: Open admin resources page
AdminUI -> Controller: GET /resources (admin view)
Controller -> Service: getAllResourcesForAdmin()
Service -> Repo: findAll()
Repo -> DB: SELECT all resources
DB --> Repo: All resource rows
Repo --> Service: List<Resource>
Service --> Controller: ResourceDTO list
Controller --> AdminUI: 200 OK + all resources
AdminUI --> Admin: Show admin table

group Create Resource
  Admin -> AdminUI: Submit new resource form
  AdminUI -> Controller: POST /resources
  Controller -> Service: createResource(payload)
  Service -> Service: validateResource(payload)

  alt Validation fails
    Service --> Controller: ValidationError
    Controller --> AdminUI: 400 Bad Request + errors
    AdminUI --> Admin: Show validation messages
  else Validation passes
    Service -> Repo: save(resource)
    Repo -> DB: INSERT resource
    DB --> Repo: New resource id
    Repo --> Service: Saved resource
    Service --> Controller: Created ResourceDTO
    Controller --> AdminUI: 201 Created
    AdminUI --> Admin: Show success + refresh list
  end
end

group Update Resource
  Admin -> AdminUI: Edit existing resource
  AdminUI -> Controller: PUT /resources/{id}
  Controller -> Service: updateResource(id, payload)
  Service -> Repo: findById(id)
  Repo -> DB: SELECT resource
  DB --> Repo: Resource / null
  Repo --> Service: Optional<Resource>

  alt Resource exists
    Service -> Service: validateResource(payload)
    Service -> Repo: save(updatedResource)
    Repo -> DB: UPDATE resource
    DB --> Repo: Updated row
    Repo --> Service: Updated resource
    Service --> Controller: Updated ResourceDTO
    Controller --> AdminUI: 200 OK
    AdminUI --> Admin: Show update success
  else Resource not found
    Service --> Controller: NotFoundException
    Controller --> AdminUI: 404 Not Found
    AdminUI --> Admin: Show "cannot update"
  end
end

group Delete Resource
  Admin -> AdminUI: Click delete + confirm
  AdminUI -> Controller: DELETE /resources/{id}
  Controller -> Service: deleteResource(id)
  Service -> Repo: existsById(id)
  Repo -> DB: SELECT existence
  DB --> Repo: true/false
  Repo --> Service: exists flag

  alt Resource exists
    Service -> Repo: deleteById(id)
    Repo -> DB: DELETE resource
    DB --> Repo: Delete complete
    Repo --> Service: done
    Service --> Controller: Delete success
    Controller --> AdminUI: 204 No Content
    AdminUI --> Admin: Remove row + show success
  else Resource missing
    Service --> Controller: NotFoundException
    Controller --> AdminUI: 404 Not Found
    AdminUI --> Admin: Show "already removed"
  end
end

== End ==

@enduml
