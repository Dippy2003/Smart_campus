@startuml
title Activity Diagram - Resource Management

|User|
start
:Open Resources page;

|System|
:Load active resource list;

|User|
:Search / filter resources;
:Select a resource;

|System|
:Display resource details and availability;

|User|
if (Want to request a booking?) then (Yes)
  :Click "Book Now";
  |System|
  :Redirect to booking module;
else (No)
  :Continue browsing resources;
endif

|Admin|
:Login as ADMIN;
:Open Admin Resources page;
:Choose Add / Update / Delete;

if (Action = Add?) then (Yes)
  :Enter new resource data;
  |System|
  :Validate required fields;
  if (Valid?) then (Yes)
    :Save resource;
    :Resource appears in public listing;
  else (No)
    :Show validation errors;
    |Admin|
    :Correct form and resubmit;
    |System|
    :Save resource;
  endif
else (No)
  if (Action = Update?) then (Yes)
    :Select existing resource;
    :Edit resource information;
    |System|
    :Validate and update resource;
  else (Delete)
    :Select resource to delete;
    :Confirm deletion;
    |System|
    :Delete resource successfully;
  endif
endif

|User|
:View current resource status/details;
stop
@enduml
